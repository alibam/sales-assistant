# ============================================
# AI Provider Configuration
# ============================================
# The system uses OpenAI-compatible API format for maximum flexibility.
#
# DEVELOPMENT: Point to third-party OpenAI-compatible API services
# PRODUCTION: Point to local Qwen inference service URL
#
# Example third-party providers:
# - https://api.openai.com/v1 (Official OpenAI)
# - https://yunyi.cfd/v1 (Third-party compatible service)
# - http://localhost:8000/v1 (Local Qwen/vLLM inference)

# Base URL for OpenAI-compatible API endpoint
OPENAI_BASE_URL=https://your-api-endpoint.com/v1

# API key for authentication
OPENAI_API_KEY=your-api-key-here

# Model name to use (must be supported by your endpoint)
# Examples: gpt-4, claude-opus-4-6, qwen-max, etc.
AI_MODEL_NAME=your-model-name

# ============================================
# RAG Embedding API Configuration
# ============================================
# Private deployment of Qwen3-embedding for vector embeddings
# Used for knowledge base semantic search

# Embedding API endpoint (OpenAI-compatible format)
EMBEDDING_API_URL=http://localhost:8000/v1/embeddings

# API key for embedding service
EMBEDDING_API_KEY=your-embedding-api-key-here

# Embedding model name (Qwen3-embedding outputs 1024 dimensions)
EMBEDDING_MODEL=qwen3-embedding

# ============================================
# Database Configuration
# ============================================
# Prisma connection string for PostgreSQL
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=your-api-key"
