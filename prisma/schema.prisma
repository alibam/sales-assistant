// OpenClaw Multi-Tenant B2B SaaS Schema
// Strict tenant isolation: every table (except Tenant) has tenant_id FK
// pgvector enabled for future AI features

generator client {
  provider = "prisma-client-js"
  // 使用默认输出路径 (node_modules/.prisma/client)
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), uuid_ossp(map: "uuid-ossp")]
}

/// @description Core tenant table for multi-tenant isolation.
/// Each tenant represents a B2B customer organization (e.g., a 4S dealership).
model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  /// @description Flexible JSONB settings per tenant (branding, feature flags, etc.)
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  customers         Customer[]
  salesStateHistory SalesStateHistory[]
  knowledgeBases    KnowledgeBase[]

  @@map("tenants")
}

/// @description Customer classification status for the sales pipeline.
/// A = Ready to Buy, B = Hesitant/Comparing, C = Low Intent/Nurture, D = Unqualified/Lost
enum CustomerStatus {
  A
  B
  C
  D
}

/// @description A customer record scoped to a specific tenant.
/// profile_data JSONB stores flexible schema fields defined by the tenant's profile_schema.json.
model Customer {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  name        String         @db.VarChar(255)
  email       String?        @db.VarChar(255)
  phone       String?        @db.VarChar(50)
  status      CustomerStatus @default(C)
  /// @description Flexible JSONB profile data. Schema varies per tenant (see profile_schema.json).
  profileData Json           @default("{}") @map("profile_data")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesStateHistory   SalesStateHistory[]
  conversationHistory ConversationHistory[]

  @@index([tenantId], map: "idx_customer_tenant_id")
  @@index([tenantId, status], map: "idx_customer_tenant_status")
  @@index([tenantId, email], map: "idx_customer_tenant_email")
  @@map("customers")
}

/// @description Immutable audit log of customer state transitions (A/B/C/D).
/// Every classification change is recorded with reason for traceability.
model SalesStateHistory {
  id         String          @id @default(uuid()) @db.Uuid
  tenantId   String          @map("tenant_id") @db.Uuid
  customerId String          @map("customer_id") @db.Uuid
  fromState  CustomerStatus? @map("from_state")
  toState    CustomerStatus  @map("to_state")
  /// @description Human-readable reason for the state transition
  reason     String?         @db.Text
  createdAt  DateTime        @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_sales_history_tenant_id")
  @@index([tenantId, customerId], map: "idx_sales_history_tenant_customer")
  @@map("sales_state_history")
}

/// @description Knowledge base for RAG (Retrieval-Augmented Generation).
/// Each tenant can have multiple knowledge bases for different purposes.
model KnowledgeBase {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks DocumentChunk[]

  @@index([tenantId], map: "idx_knowledge_base_tenant_id")
  @@map("knowledge_bases")
}

/// @description Conversation history for dual-track profile collection.
/// Tracks user-AI interactions in both Copilot and Post-Call modes.
model ConversationHistory {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  role       String   @db.VarChar(20) // 'user' | 'assistant'
  content    String   @db.Text
  mode       String   @db.VarChar(20) // 'copilot' | 'postCall'
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, tenantId], map: "idx_conversation_customer_tenant")
  @@index([tenantId], map: "idx_conversation_tenant_id")
  @@map("conversation_history")
}

/// @description Document chunks with vector embeddings for semantic search.
/// Uses Qwen3-embedding (1024 dimensions) for private deployment.
model DocumentChunk {
  id              String                       @id @default(uuid()) @db.Uuid
  tenantId        String                       @map("tenant_id") @db.Uuid
  knowledgeBaseId String                       @map("knowledge_base_id") @db.Uuid
  content         String                       @db.Text
  /// @description Metadata: document source, page number, etc.
  metadata        Json?
  /// @description Vector embedding from Qwen3-embedding (1024 dimensions)
  embedding       Unsupported("vector(1024)")?
  createdAt       DateTime                     @default(now()) @map("created_at")
  updatedAt       DateTime                     @updatedAt @map("updated_at")

  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_document_chunk_tenant_id")
  @@index([knowledgeBaseId], map: "idx_document_chunk_kb_id")
  @@map("document_chunks")
}
